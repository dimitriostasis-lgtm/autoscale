{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run AutoScale Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"Autoscale-Server",
				"run",
				"start:dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run AutoScale Client",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"AutoScale-Client",
				"run",
				"dev",
				"--",
				"--host",
				"0.0.0.0"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}