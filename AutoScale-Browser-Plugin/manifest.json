{
  "manifest_version": 3,
  "name": "AutoScale Robot Capture",
  "version": "0.1.0",
  "description": "Detect primary images, videos, and audio on webpages and send selected assets to AutoScale workspace tables.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "AutoScale Robot",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
